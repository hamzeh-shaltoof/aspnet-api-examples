{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://ops.seq:5341",
          "apiKey": "igftWRYbpITFLwEXxCdf"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "paymentservice"
    }
  },
  "OpenTelemetry": {
    "Endpoint": "http://ops.seq:5341/ingest/otlp/v1/traces"
  },
  "AllowedHosts": "*",
  "PaymentGateway": {
    "ApiKey": "ABCD1234"
  }
}
