@model IEnumerable<Product>

@{
	ViewData["Title"] = "List All Data";
}
<div class="container mt-5" dir="ltr">
    <div class="card shadow-sm">
        <!-- Header with English text and Add Button -->
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Product List</h5>
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Add New Product
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Product Name</th>
                            <th>Price</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td class="fw-bold">@product.Name</td>
                                <td>@product.Price.ToString("C")</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <!-- View Details -->
                                        <a class="btn btn-outline-info btn-sm"
                                           asp-action="Details" asp-route-id="@product.Id" title="Details">
                                            <i class="fas fa-eye"></i> Details
                                        </a>

                                        <!-- Edit Product -->
                                        <a class="btn btn-outline-warning btn-sm"
                                           asp-action="Edit" asp-route-id="@product.Id" title="Edit">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>

                                        <!-- Delete Product -->
                                        <a class="btn btn-outline-danger btn-sm" onclick="confirmDelete()"
                                           asp-action="Delete" asp-route-id="@product.Id" title="Delete">
                                            <i class="fas fa-trash-alt"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
