@model M01.ModelAndInMemoryStoreSetupMVC.Model.Product

@{
	ViewData["Title"] = "Edit Of Single";
}


<div class="container mt-5" dir="ltr">
    <div class="card shadow-sm border-0">
        <!-- الهيدر بلون Edit (Warning) -->
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Edit Product</h5>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="POST">
                <input asp-for="Id" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Product Name</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-bold">Price</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="form-label fw-bold">Category</label>
                        <input asp-for="Category" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <hr />

                <div class="mt-3">
                    <button type="submit" class="btn btn-success px-4">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

