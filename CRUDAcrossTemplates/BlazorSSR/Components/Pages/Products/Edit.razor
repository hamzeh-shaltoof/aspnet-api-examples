@page "/Products/Edit/{id:guid}"
@rendermode InteractiveServer // Update Automatically

<h3>Edit Product @Product.Name @Product.Id Use Blazor Pages </h3>


<div class="container mt-5" dir="ltr">
    <div class="card shadow-sm border-0">
        <!-- الهيدر بلون Edit (Warning) -->
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Edit Product</h5>
        </div>

        <div class="card-body p-4">
            <EditForm Model="Product"  OnValidSubmit="Update" FormName="Edit-Product">

                <div class="mb-3">
                    <label  class="form-label fw-bold">Name</label>
                    <InputText @bind-value="Product.Name" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Product.Price" class="form-label fw-bold">Price</label>
                        <InputNumber @bind-value="Product.Price" type="number" step="0.01" class="form-control"   />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label  class="form-label fw-bold">@Product.Category</label>
                        <InputText @bind-value="@Product.Category" class="form-control"  />
                    </div>
                </div>

                <div class="mb-3">
                    <label  class="form-label fw-bold">Description</label>
                    <InputTextArea @bind-value="@Product.Description" class="form-control" rows="3">@Product.Description</InputTextArea>
                </div>

                <hr />

                <div class="mt-3">
                    <button type="submit" class="btn btn-success px-4">Save Changes</button>
                    <a href=@($"/Products") class="btn btn-secondary px-4">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>


@code {
    [Inject]
    public ProductStore Store { get; private set; } = null!;

    [Inject]
    public NavigationManager Navigation { get; set; }

    [Parameter]
    public Guid Id { get;  set; }

    private Product Product { get; set; } = null!;

    protected override void OnInitialized()
    {
        var originalProduct = Store.GetById(Id)!;  
        // هون بيرجع كمرجع يعني اي تغير من الفورم رح يغير على المنتج الاصلي مباشرة لئني رابطهم مع بعض
        // لذالك لازم الفصل بينهم , يعني الي حيجبو من المخزن يجب عدم العرض على الفورم 
        // وعشان اعرض البيانات علىى الفورم لازم ما اسندهم بالبايند لنفس المرجع لئنو رح يعمل تحديث للمخزن مباشرة من غير كبسة الحفظ
        // فلهيك الفصل بينهم بحيث اعرض   البيانات المخزن واسندها  بكائن جديد ليس له مرجع  بالمخزن 
        // ومن ثم عند الضغط على الحفظ يعدل على المخزن

         this.Product = new Product
        {
            Id = originalProduct.Id,
            Name = originalProduct.Name,
            Price = originalProduct.Price,
            Category = originalProduct.Category,
            Description = originalProduct.Description
        };
      

        if (Product is null)
            Navigation.NavigateTo("/Products");

    }
    public async Task Update()
    {
        Store.Update(Product);

			Navigation.NavigateTo("/Products");
		
	}


}


