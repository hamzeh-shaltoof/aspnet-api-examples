@page "/Products/details/{id:guid}"
@rendermode InteractiveServer
@using Microsoft.JSInterop

<h3>Details Product Use Blazor Page</h3>

<div class="container mt-5" dir="ltr">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Product Details</h5>
        </div>

        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">ID</dt>
                <dd class="col-sm-9 fw-bold">@Product?.Id</dd>

                <hr class="text-light">

                <dt class="col-sm-3 text-muted">Product Name</dt>
                <dd class="col-sm-9">@Product?.Name</dd>

                <hr class="text-light">

                <dt class="col-sm-3 text-muted">Price</dt>
                <dd class="col-sm-9 text-success fw-bold">@Product?.Price.ToString("C")</dd>

                <hr class="text-light">

                <dt class="col-sm-3 text-muted">Category</dt>
                <dd class="col-sm-9"><span class="badge bg-light text-dark border">@Product?.Category</span></dd>

                <hr class="text-light">

                <dt class="col-sm-3 text-muted">Description</dt>
                <dd class="col-sm-9 text-secondary">@(Product?.Description ?? "No description available")</dd>
            </dl>

            <div class="mt-4 pt-3 border-top d-flex gap-2">
                <NavLink href=@($"/Products") class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </NavLink>

                <NavLink href=@($"/Products/Edit/{Product.Id}") asp-route-id="Product?.Id" class="btn btn-warning text-white">
                    <i class="fas fa-edit"></i> Edit
                </NavLink>

                <a @onclick="CallConfirmDelete" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Delete
                </a>
            </div>
        </div>
    </div>
</div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
    function confirmDelete(refThisComponent,id) {
            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "delete"
            }).then((result) => {
                if (result.isConfirmed) {
                    refThisComponent.invokeMethodAsync("Delete",id);
                }
            });
        }
    </script>


@code {
    [Inject]
    public ProductStore Store { get; set; } = null!;

    [Inject]
    public IJSRuntime JS { get; set; } 

    [Inject]
    public NavigationManager Navigation { get; set; } = null!;

    public Product? Product { get; set; } = null!;




    [Parameter]
    public Guid Id { get; set; }

    protected override void OnParametersSet() // This Function Is Executed Directly Upon Inputting The Parameter
    {
        Product = Store.GetById(Id) ?? throw new Exception();
    }
    public async Task CallConfirmDelete()
    {
        var refThisComponent = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("confirmDelete", refThisComponent, Id);

    }

    [JSInvokable]
    public void Delete()
    {
        var product = Store.GetById(Id) ?? throw new ArgumentNullException();


        Store.Delete(product!);

        Navigation.NavigateTo("/Products", forceLoad: true);

    }

}
