@page "/Products"
@rendermode InteractiveServer
@using Microsoft.JSInterop
<h3>All Data Use Blazor Page</h3>




<div class="container mt-5" dir="ltr">
    <div class="card shadow-sm">
        <!-- Header with English text and Add Button -->
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Product List</h5>
            <NavLink href=@($"/Products/Create") class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Add New Product
            </NavLink>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Product Name</th>
                            <th>Price</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Products)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td class="fw-bold">@product.Name</td>
                                <td>@product.Price.ToString("C")</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <!-- زر التفاصيل: تأكد من وجود asp-page و asp-route-id مرة واحدة فقط -->
                                        <NavLink class="btn btn-outline-info btn-sm"
                                                 href=@($"/Products/Details/{product.Id}")>
                                            <i class="fas fa-eye"></i> Details
                                        </NavLink>

                                        <!-- زر التعديل -->
                                        <NavLink class="btn btn-outline-warning btn-sm"
                                                 href=@($"/Products/Edit/{product.Id}")>
                                            <i class="fas fa-edit"></i> Edit
                                        </NavLink>

                                        <!-- زر الحذف -->
                                        <a class="btn btn-outline-danger btn-sm"
                                           
                                                 @onclick="() => CallConfirmDelete(product.Id)">
                                            <i class="fas fa-trash-alt"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

 
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
    function confirmDelete(refThisComponent,id) {
            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "delete"
            }).then((result) => {
                if (result.isConfirmed) {
                refThisComponent.invokeMethodAsync("OnDeleteProduct" , id)
                }
            });
        }
    </script>

@code {
    [Inject]
    public  ProductStore Store { get; set; } = null!;

    [Inject] public Microsoft.JSInterop.IJSRuntime JS { get; set; }

    public  IEnumerable<Product> Products { get; set; } = null!;

    protected override void OnInitialized() 
    {
        Products = Store.GetAll();
    }

    public async Task CallConfirmDelete(Guid id)
    {
        var refThisComponent = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("confirmDelete", refThisComponent, id);
     
    }

    [JSInvokable]
    public  void OnDeleteProduct(Guid id)
    {
        var product = Store.GetById(id);

        if (product != null)
            Store.Delete(product);

        Products = Store.GetAll(); // مهم جداً
        StateHasChanged();
    }


}
