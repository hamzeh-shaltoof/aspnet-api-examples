@page 
@model IndexModel

@{
    ViewData["Title"] = "List All Data Use Razor Pages";
}
<div class="container mt-5" dir="ltr">
    <div class="card shadow-sm">
        <!-- Header with English text and Add Button -->
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Product List</h5>
            <a asp-page="Create" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Add New Product
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Product Name</th>
                            <th>Price</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td class="fw-bold">@product.Name</td>
                                <td>@product.Price.ToString("C")</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <!-- زر التفاصيل: تأكد من وجود asp-page و asp-route-id مرة واحدة فقط -->
                                        <a class="btn btn-outline-info btn-sm"
                                           asp-page="/Products/Details"
                                           asp-route-id="@product.Id">
                                            <i class="fas fa-eye"></i> Details
                                        </a>

                                        <!-- زر التعديل -->
                                        <a class="btn btn-outline-warning btn-sm"
                                           asp-page="/Products/Edit"
                                           asp-route-id="@product.Id">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>

                                        <!-- زر الحذف -->
                                        <a class="btn btn-outline-danger btn-sm"
                                           href="#"
                                           onclick="confirmDelete('@Url.Page("/Products/Index","Delete",new {product.Id})')">
                                            <i class="fas fa-trash-alt"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete(url) {
            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "delete"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        }
    </script>
}